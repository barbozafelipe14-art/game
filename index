  <!-- AI CHAT WIDGET -->
  <div class="ai-fab" id="ai-fab" onclick="toggleChat()">🌹</div>
  <div class="ai-chat" id="ai-chat">
    <div class="ai-header">
      <div class="ai-title"><div class="ai-status" id="ai-status"></div> Aphrodite AI</div>
      <div class="ai-close" onclick="toggleChat()">✕</div>
    </div>
    <div class="ai-messages" id="ai-messages">
      <div class="ai-msg bot">Welcome to the Vault, darling. I am your host and referee. Ask me about the rules, or tell me if someone is cheating. 😈<br><br><em>(Note: Paste your API key in Settings for live responses. Otherwise, I will use my local rulebook.)</em></div>
    </div>
    <div class="ai-input-area">
      <input type="text" class="ai-input" id="ai-input" placeholder="Ask Aphrodite..." onkeydown="if(event.key==='Enter')sendAiMsg()">
      <button class="ai-send" onclick="sendAiMsg()">➤</button>
    </div>
  </div>

  <!-- TOASTS -->
  <div class="toast-container" id="toast-container"></div>

  <script>
    // --- AUDIO & HAPTICS ---
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    document.addEventListener('click', () => { if (audioCtx.state === 'suspended') audioCtx.resume(); }, { once: true });

    function playSound(type) {
      try {
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        
        if (type === 'tick') {
          osc.type = 'sine'; osc.frequency.setValueAtTime(800, audioCtx.currentTime);
          gain.gain.setValueAtTime(0.05, audioCtx.currentTime);
          gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.05);
          osc.start(); osc.stop(audioCtx.currentTime + 0.05);
        } else if (type === 'achieve') {
          osc.type = 'sine';
          osc.frequency.setValueAtTime(523, audioCtx.currentTime);
          osc.frequency.setValueAtTime(659, audioCtx.currentTime + 0.1);
          osc.frequency.setValueAtTime(784, audioCtx.currentTime + 0.2);
          gain.gain.setValueAtTime(0.15, audioCtx.currentTime);
          gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.4);
          osc.start(); osc.stop(audioCtx.currentTime + 0.4);
        } else if (type === 'boom') {
          osc.type = 'sawtooth';
          osc.frequency.setValueAtTime(100, audioCtx.currentTime);
          osc.frequency.exponentialRampToValueAtTime(20, audioCtx.currentTime + 0.5);
          gain.gain.setValueAtTime(0.3, audioCtx.currentTime);
          gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.5);
          osc.start(); osc.stop(audioCtx.currentTime + 0.5);
        }
      } catch(e) {}
    }

    function haptic(ms) {
      if (navigator.vibrate) navigator.vibrate(ms);
    }

    // --- STATE & DATABASE ---
    const state = {
      players: [],
      currentTurn: 0,
      boardSize: 50,
      vibe: 'friendly',
      mood: 'open',
      intensity: 3,
      pin: '1234',
      isLocked: false,
      memory: [],
      relationships: {},
      achievements: new Set(),
      turnCount: 0,
      settings: { apiKey: '', apiUrl: 'https://api.openai.com/v1/chat/completions' }
    };

    const TOKEN_COLORS = ['#ff2d55', '#4ade80', '#3b82f6', '#f59e0b', '#8b5cf6', '#ec4899', '#06b6d4', '#f97316'];
    const TITLES = ['Initiate', 'Intimate', 'Temptation', 'Vault', 'Olympus'];
    const XP_THRESHOLDS = [0, 100, 250, 500, 1000];

    // Procedural Prompt Fragments
    const promptFragments = {
      friendly: {
        actions: ["give a genuine compliment to", "ask about the proudest moment of", "share a harmless secret with", "describe the best first impression of"],
        conditions: ["while maintaining unbroken eye contact for 10 seconds.", "while the rest of the group watches.", "in the most dramatic voice possible."]
      },
      couple: {
        actions: ["trace the jawline of", "whisper a fantasy you've had about", "blindfold and kiss the neck of", "hold the hand of and trace the palm of"],
        conditions: ["without speaking a single word.", "while describing exactly what you feel.", "for 30 seconds without breaking contact."]
      },
      hot: {
        actions: ["sit on the lap of", "feed a drink to", "give a 60-second sensual shoulder massage to", "whisper your deepest desire into the ear of"],
        conditions: ["using only your non-dominant hand.", "while the group counts down from 10.", "with your eyes closed."]
      },
      aphrodite: [
        "APHRODITE DEMANDS: Everyone must swap seats. The last to sit loses 20 XP.",
        "APHRODITE DEMANDS: {player} and {target} must maintain eye contact for 30 seconds. If either looks away, both lose 10 XP.",
        "APHRODITE DEMANDS: For the next round, all answers must be whispered. Speaking aloud results in a penalty."
      ],
      chaos: [
        "CHAOS: {player} must spin around 5 times, then attempt to give {target} a sensual compliment.",
        "CHAOS: The player with the lowest XP chooses a new rule for the next 3 rounds.",
        "CHAOS: {player} must trade places with {target} on the board, and {target} must complete {player}'s next challenge."
      ]
    };

    // --- SETUP LOGIC ---
    let tempSetup = {};

    document.querySelectorAll('#player-count-options .setup-option').forEach(opt => {
      opt.onclick = () => {
        document.querySelectorAll('#player-count-options .setup-option').forEach(o => o.classList.remove('selected'));
        opt.classList.add('selected');
        tempSetup.count = parseInt(opt.dataset.val);
      };
    });

    document.querySelectorAll('#vibe-options .setup-option').forEach(opt => {
      opt.onclick = () => {
        document.querySelectorAll('#vibe-options .setup-option').forEach(o => o.classList.remove('selected'));
        opt.classList.add('selected');
        tempSetup.vibe = opt.dataset.val;
      };
    });

    document.querySelectorAll('#mood-options .setup-option').forEach(opt => {
      opt.onclick = () => {
        document.querySelectorAll('#mood-options .setup-option').forEach(o => o.classList.remove('selected'));
        opt.classList.add('selected');
        tempSetup.mood = opt.dataset.val;
      };
    });

    function updateIntensityLabel(val) {
      const labels = ["", "Gentle", "Warm", "Balanced", "Spicy", "Intense"];
      // Visual feedback only, actual value saved on start
    }

    function nextStep(current) {
      if (current === 1) {
        if (!tempSetup.count) return alert('Select player count.');
        const container = document.getElementById('names-container');
        container.innerHTML = '';
        for (let i = 0; i < tempSetup.count; i++) {
          container.innerHTML += `
            <div class="setup-input-group">
              <input type="text" class="setup-input p-name" placeholder="Player ${i+1} Name" value="Player ${i+1}" style="grid-column: 1 / -1;">
              <select class="setup-select p-gender">
                <option value="M">Male</option>
                <option value="F">Female</option>
                <option value="NB">Non-Binary</option>
              </select>
              <select class="setup-select p-rel">
                <option value="Single">Single</option>
                <option value="Taken">In a Relationship</option>
                <option value="Complicated">It's Complicated</option>
              </select>
              <label style="grid-column: 1 / -1; display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--gold); cursor: pointer;">
                <input type="checkbox" class="p-host" ${i===0?'checked':''}> Mark as Host ★
              </label
</div>
          `;
        }
      }
      if (current === 2) {
        const names = document.querySelectorAll('.p-name');
        const genders = document.querySelectorAll('.p-gender');
        const rels = document.querySelectorAll('.p-rel');
        const hosts = document.querySelectorAll('.p-host');
        state.players = Array.from(names).map((n, i) => ({
          name: n.value.trim() || `P${i+1}`,
          gender: genders[i].value,
          relationship: rels[i].value,
          isHost: hosts[i].checked,
          position: 0,
          xp: 0,
          level: 1,
          color: TOKEN_COLORS[i % TOKEN_COLORS.length],
          stats: { completed: 0, refused: 0, targeted: 0, xpGained: 0 }
        }));
        
        state.players.forEach((p1, i) => {
          state.relationships[i] = {};
          state.players.forEach((p2, j) => {
            if (i !== j) state.relationships[i][j] = 10;
          });
        });
      }
      if (current === 3) {
        if (!tempSetup.vibe) return alert('Select a vibe.');
        state.vibe = tempSetup.vibe;
      }
      if (current === 4) {
        if (!tempSetup.mood) return alert('Select a mood.');
        state.mood = tempSetup.mood;
      }
      if (current === 5) {
        const pin = document.getElementById('vault-pin').value;
        if (pin.length !== 4) return alert('PIN must be 4 digits.');
        state.pin = pin;
        state.intensity = parseInt(document.getElementById('intensity-range').value);
      }
      
      document.getElementById(`step-${current}`).classList.add('hidden');
      document.getElementById(`step-${current + 1}`).classList.remove('hidden');
      saveGame();
    }

    function prevStep(current) {
      document.getElementById(`step-${current}`).classList.add('hidden');
      document.getElementById(`step-${current - 1}`).classList.remove('hidden');
    }

    function startGame() {
      document.getElementById('setup-container').classList.add('hidden');
      document.getElementById('game-ui').classList.add('active');
      initBoard();
      updateUI();
      saveGame();
    }

    // --- BOARD ENGINE ---
    function initBoard() {
      const container = document.getElementById('board-container');
      const size = container.clientWidth;
      const center = size / 2;
      const radius = size * 0.42;

      const svg = document.getElementById('board-svg');
      svg.innerHTML = `<circle cx="${center}" cy="${center}" r="${radius}" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="2" stroke-dasharray="4,4" />`;

      for (let i = 0; i < state.boardSize; i++) {
        const angle = (i / state.boardSize) * 2 * Math.PI - Math.PI / 2;
        const x = center + radius * Math.cos(angle);
        const y = center + radius * Math.sin(angle);
        
        const node = document.createElement('div');
        node.className = 'board-node';
        node.style.left = `${x}px`;
        node.style.top = `${y}px`;
        node.dataset.index = i;
        
        let type = 'challenge';
        if (i === state.boardSize - 1) type = 'olympus';
        else if (i % 7 === 0) type = 'aphrodite';
        else if (i % 5 === 0) type = 'vault';
        else if (i % 4 === 0) type = 'reward';
        else if (i % 9 === 0) type = 'chaos';
        
        node.classList.add(`type-${type}`);
        container.appendChild(node);
      }

      state.players.forEach((p, i) => {
        const token = document.createElement('div');
        token.className = 'player-token';
        token.id = `token-${i}`;
        token.style.backgroundColor = p.color;
        token.style.color = p.color;
        token.textContent = p.name[0];
        container.appendChild(token);
      });

      updateTokens();
    }

    function updateTokens() {
      const container = document.getElementById('board-container');
      const size = container.clientWidth;
      const center = size / 2;
      const radius = size * 0.42;

      state.players.forEach((p, i) => {
        const angle = (p.position / state.boardSize) * 2 * Math.PI - Math.PI / 2;
        const x = center + radius * Math.cos(angle);
        const y = center + radius * Math.sin(angle);
        
        const offsetAngle = (i / state.players.length) * 2 * Math.PI;
        const offsetX = 10 * Math.cos(offsetAngle);
        const offsetY = 10 * Math.sin(offsetAngle);
        
        const token = document.getElementById(`token-${i}`);
        token.style.left = `${x + offsetX}px`;
        token.style.top = `${y + offsetY}px`;
      });

      document.querySelectorAll('.board-node').forEach(n => n.classList.remove('active'));
      const activeNode = document.querySelector(`.board-node[data-index="${state.players[state.currentTurn].position}"]`);
      if(activeNode) activeNode.classList.add('active');
    }

    // --- FIXED MOVEMENT ENGINE ---
    let isMoving = false;

    async function movePlayer(steps) {
      if (isMoving) return;
      isMoving = true;
      document.getElementById('roll-action-btn').disabled = true;
      
      const player = state.players[state.currentTurn];
      
      for (let i = 0; i < steps; i++) {
        player.position = (player.position + 1) % state.boardSize;
        updateTokens();
        playSound('tick');
        haptic(30);
        await new Promise(r => setTimeout(r, 250));
      }
      
      isMoving = false;
      handleLanding();
    }

    function rollDice() {
      if (isMoving) return;
      const diceBtn = document.getElementById('dice-btn');
      diceBtn.classList.add('rolling');
      haptic(50);
      
      let count = 0;
      const interval = setInterval(() => {
        diceBtn.textContent = Math.floor(Math.random() * 6) + 1;
        count++;
        if (count > 12) {
          clearInterval(interval);
          const finalRoll = Math.floor(Math.random() * 6) + 1;
          diceBtn.textContent = finalRoll;
          diceBtn.classList.remove('rolling');
          movePlayer(finalRoll);
        }
      }, 60);
    }

    function handleLanding() {
      const pos = state.players[state.currentTurn].position;
      const node = document.querySelector(`.board-node[data-index="${pos}"]`);
      const type = node ? Array.from(node.classList).find(c => c.startsWith('type-')).replace('type-', '') : 'challenge';
      
      if (type === 'olympus') {
        triggerVictory();
      } else if (type === 'aphrodite' || type === 'chaos') {
        triggerCinematic(type);
      } else {
        drawCard(type);
      }
      saveGame();
    }

    // --- PROCEDURAL PROMPT ENGINE ---
    function generatePrompt(spaceType) {
      const player = state.players[state.currentTurn];
      const targets = state.players.filter((_, i) => i !== state.currentTurn);
      const target = targets[Math.floor(Math.random() * targets.length)];
      
      state.relationships[state.currentTurn][state.players.indexOf(target)] += 2;
      target.stats.targeted++;

      // 25% chance for Memory Callback
      if (state.memory.length > 0 && Math.random() < 0.25) {
        const relevantMem = state.memory.filter(m => m.actor === player.name || m.target === player.name);
        if (relevantMem.length > 0) {
          const mem = relevantMem[Math.floor(Math.random() * relevantMem.length)];
          return {
            text: `The Vault remembers: Earlier, ${mem.actor} made ${mem.target} ${mem.action}. Now, the roles reverse. <strong style="color:${player.color}">${player.name}</strong>, make <strong style="color:${target.color}">${target.name}</strong> ${mem.action} for 15 seconds.`,
            cat: "Memory Callback",
            xp: 30,
            target: target.name
          };
        }
      }

      // Procedural Generation
      let pool = promptFragments.friendly;
      if (state.vibe === 'couple' || (state.intensity >= 4 && state.vibe === 'friendly')) pool = promptFragments.couple;
      if (state.vibe === 'hot' || state.intensity >= 5) pool = promptFragments.hot;
      if (spaceType === 'aphrodite') return { text: randomFrom(promptFragments.aphrodite).replace(/{player}/g, `<strong>${player.name}</strong>`).replace(/{target}/g, `<strong>${target.name}</strong>`), cat: "Divine Intervention", xp: 40, target: "Group" };
      if (spaceType === 'chaos') return { text: randomFrom(promptFragments.chaos).replace(/{player}/g, `<strong>${player.name}</strong>`).replace(/{target}/g, `<strong>${target.name}</strong>`), cat: "Chaos Cascade", xp: 20, target: "Group" };

      const action = randomFrom(pool.actions);
      const condition = randomFrom(pool.conditions);
      
      return {
        text: `<strong style="color:${player.color}">${player.name}</strong>, ${action} <strong style="color:${target.color}">${target.name}</strong> ${condition}`,
        cat: spaceType.charAt(0).toUpperCase() + spaceType.slice(1),
        xp: 20,
        target: target.name
      };
    }

    function drawCard(spaceType) {
      const modal = document.getElementById('card-modal');
      const promptData = generatePrompt(spaceType);
      
      document.getElementById('modal-cat').textContent = promptData.cat;
      document.getElementById('modal-text').innerHTML = promptData.text;
      document.getElementById('modal-target').textContent = `Target: ${promptData.target}`;
      document.getElementById('modal-xp').textContent = `+${promptData.xp} XP`;
      
      modal.dataset.xp = promptData.xp;
      modal.dataset.targetName = promptData.target;
      modal.classList.add('active');
      haptic(50);
    }

    function completeChallenge() {
      const modal = document.getElementById('card-modal');
      const xp = parseInt(modal.dataset.xp);
      const targetName = modal.dataset.targetName;
      const player = state.players[state.currentTurn];

      state.memory.push({
        type: 'completed',
        actor: player.name,
        target: targetName,
        action: 'completed a challenge',
        turn: state.turnCount
      });

      player.stats.completed++;
      player.stats.xpGained += xp;
      addXP(xp);
      
      modal.classList.remove('active');
      nextTurn();
    }

    function refuseChallenge() {
      const modal = document.getElementById('card-modal');
      const player = state.players[state.currentTurn];
      
      state.memory.push({
        type: 'refused',
        actor: player.name,
        target: 'None',
        action: 'refused a challenge',
        turn: state.turnCount
      });
      
      player.stats.refused++;
      addXP(-10);
      modal.classList.remove('active');
      showToast('⛓️ Penalty', `${player.name} refused the challenge. -10 XP`);
      nextTurn();
    }

    function nextTurn() {
      state.currentTurn = (state.currentTurn + 1) % state.players.length;
      state.turnCount++;
      updateUI();
      updateTokens();
      document.getElementById('roll-action-btn').disabled = false;
      saveGame();
    }

    // --- PROGRESSION ---
    function addXP(amount) {
      const player = state.players[state.currentTurn];
      player.xp += amount;
      
      const nextLevelIdx = player.level;
      if (nextLevelIdx < 5 && player.xp >= XP_THRESHOLDS[nextLevelIdx]) {
        player.level++;
        unlock('LEVEL_UP', `Level ${player.level}: ${TITLES[player.level-1]}`, `Unlocked new prompt tiers`);
        haptic([100, 50, 100]);
      }
      updateUI();
    }

    function updateUI() {
      const player = state.players[state.currentTurn];
      document.getElementById('current-player-name').textContent = player.name;
      document.getElementById('current-player-name').style.color = player.color;
      document.getElementById('player-level').textContent = `LVL ${player.level}`;
      
      const currentThreshold = XP_THRESHOLDS[player.level - 1];
      const nextThreshold = XP_THRESHOLDS[player.level] || currentThreshold + 500;
      const progress = ((player.xp - currentThreshold) / (nextThreshold - currentThreshold)) * 100;
      document.getElementById('xp-fill').style.width = `${Math.min(100, Math.max(0, progress))}%`;

      // Dynamic Heat Background
      const heatHue = Math.max(0, 280 - (state.turnCount * 2));
      document.documentElement.style.setProperty('--heat-hue', heatHue);
    }

    function unlock(id, title, desc) {
      if (state.achievements.has(id)) return;
      state.achievements.add(id);
      playSound('achieve');
      showToast('🏆 ' + title, desc);
      saveGame();
    }

    function showToast(title, desc) {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      toast.className = 'toast';
      toast.innerHTML = `
        <div class="toast-content">
          <div class="toast-title">${title}</div>
          <div class="toast-desc">${desc}</div>
        </div>
      `;
      container.appendChild(toast);
      setTimeout(() => toast.remove(), 4000);
    }

    // --- CINEMATIC EVENTS ---
    function triggerCinematic(type) {
      document.body.classList.add('shake');
      setTimeout(() => document.body.classList.remove('shake'), 500);
      
      const overlay = document.getElementById('cinematic-overlay');
      overlay.classList.add('active');
      startParticles();
      playSound('boom');
      haptic([200, 100, 200]);
      
      const events = type === 'aphrodite' ? promptFragments.aphrodite : promptFragments.chaos;
      const player = state.players[state.currentTurn];
      const target = state.players[(state.currentTurn+1)%state.players.length];
      const text = randomFrom(events)
        .replace(/{player}/g, `<strong style="color:${player.color}">${player.name}</strong>`)
        .replace(/{target}/g, `<strong style="color:${target.color}">${target.name}</strong>`);
      
      document.getElementById('cinematic-title').textContent = type === 'aphrodite' ? "APHRODITE STORM" : "CHAOS CASCADE";
      document.getElementById('cinematic-text').innerHTML = text;
      
      unlock('DIVINE_INTERVENTION', 'Divine Intervention', 'Survived a cinematic event');
    }

    function closeCinematic() {
      document.getElementById('cinematic-overlay').classList.remove('active');
      nextTurn();
    }

    function triggerVictory() {
      const player = state.players[state.currentTurn];
      document.getElementById('cinematic-title').textContent = "OLYMPUS GATE";
      document.getElementById('cinematic-title').style.color = "var(--gold)";
      document.getElementById('cinematic-text').innerHTML = `<strong style="color:${player.color}">${player.name}</strong> has reached Level 5 and claimed the Vault Crown.`;
      document.getElementById('cinematic-overlay').classList.add('active');
      startParticles('#particle-canvas', '#d4af37');
      playSound('achieve');
    }

    // --- PARTICLE SYSTEM ---
    function startParticles(canvasId = 'particle-canvas', colorOverride = null) {
      const canvas = document.getElementById(canvasId);
      const ctx = canvas.getContext('2d');
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      let particles = [];
      
      for (let i = 0; i < 120; i++) {
        particles.push({
          x: canvas.width / 2,
          y: canvas.height / 2,
          vx: (Math.random() - 0.5) * 12,
          vy: (Math.random() - 0.5) * 12,
          life: 1,
          color: colorOverride || (Math.random() > 0.5 ? '#ff2d55' : '#d4af37')
        });
      }

      function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        particles.forEach(p => {
          p.x += p.vx;
          p.y += p.vy;
          p.vy += 0.05;
          p.life -= 0.008;
          ctx.fillStyle = p.color;
          ctx.globalAlpha = p.life;
          ctx.beginPath();
          ctx.arc(p.x, p.y, 3, 0, Math.PI * 2);
          ctx.fill();
        });
        particles = particles.filter(p => p.life > 0);
        if (particles.length > 0) requestAnimationFrame(animate);
      }
      animate();
    }

    // --- LOCK SYSTEM ---
    let currentPin = "";
    function toggleLock() {
      state.isLocked = !state.isLocked;
      document.getElementById('lock-screen').classList.toggle('active', state.isLocked);
      currentPin = "";
      updatePinDots();
      saveGame();
    }

    function enterPin(num) {
      if (currentPin.length < 4) {
        currentPin += num;
        updatePinDots();
        haptic(20);
      }
    }

    function clearPin() {
      currentPin = "";
      updatePinDots();
    }

    function submitPin() {
      if (currentPin === state.pin) {
        state.isLocked = false;
        document.getElementById('lock-screen').classList.remove('active');
        haptic([50, 50, 50]);
      } else {
        haptic(200);
        currentPin = "";
        updatePinDots();
        showToast('🔒 Access Denied', 'Incorrect PIN');
      }
    }

    function updatePinDots() {
      const dots = document.querySelectorAll('.pin-dot');
      dots.forEach((dot, i) => {
        dot.classList.toggle('filled', i < currentPin.length);
      });
    }

    // --- HOST PANEL & SETTINGS ---
    function openHostPanel() {
      const logEl = document.getElementById('host-log');
      logEl.innerHTML = state.memory.length ? state.memory.map(m => `[Turn ${m.turn}] ${m.actor} → ${m.action} (${m.target})`).join('<br>') : 'No entries yet.';
      document.getElementById('host-modal').classList.add('active');
    }
    function closeHostPanel() { document.getElementById('host-modal').classList.remove('active'); }

    function hostAction(action) {
      if (action === 'skip') {
        nextTurn();
        closeHostPanel();
      } else if (action === 'aphrodite') {
        closeHostPanel();
        triggerCinematic('aphrodite');
      } else if (action === 'reset') {
        state.players.forEach(p => { p.xp = 0; p.level = 1; p.stats = { completed: 0, refused: 0, targeted: 0, xpGained: 0 }; });
        state.turnCount = 0;
        state.memory = [];
        updateUI();
        closeHostPanel();
        showToast('🔄 Reset', 'All scores and memory cleared.');
      } else if (action === 'end') {
        location.reload();
      }
      saveGame();
    }

    function openSettings() {
      document.getElementById('api-key-input').value = state.settings.apiKey;
      document.getElementById('api-url-input').value = state.settings.apiUrl;
      document.getElementById('settings-intensity').value = state.intensity;
      document.getElementById('settings-modal').classList.add('active');
    }
    function closeSettings() { document.getElementById('settings-modal').classList.remove('active'); }

    function saveSettings() {
      state.settings.apiKey = document.getElementById('api-key-input').value.trim();
      state.settings.apiUrl = document.getElementById('api-url-input').value.trim();
      state.intensity = parseInt(document.getElementById('settings-intensity').value);
      closeSettings();
      saveGame();
      showToast('⚙️ Settings', 'API and intensity updated.');
      
      // Update AI status indicator
      const statusEl = document.getElementById('ai-status');
      if (state.settings.apiKey) {
        statusEl.classList.remove('offline');
        document.querySelector('.ai-fab').classList.add('pulse');
      } else {
        statusEl.classList.add('offline');
        document.querySelector('.ai-fab').classList.remove('pulse');
      }
    }

    function exportSave() {
      const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(state));
      const downloadAnchorNode = document.createElement('a');
      downloadAnchorNode.setAttribute("href", dataStr);
      downloadAnchorNode.setAttribute("download", "the_vault_save.json");
      document.body.appendChild(downloadAnchorNode);
      downloadAnchorNode.click();
      downloadAnchorNode.remove();
    }

    // --- AI CHAT ENGINE ---
    function toggleChat() {
      document.getElementById('ai-chat').classList.toggle('active');
    }

    async function sendAiMsg() {
      const input = document.getElementById('ai-input');
      const msg = input.value.trim();
      if (!msg) return;

      addAiMsg(msg, 'user');
      input.value = '';

      // Show typing indicator
      const typingId = 'typing-' + Date.now();
      addAiMsg('Aphrodite is thinking...', 'bot', typingId);

      if (state.settings.apiKey) {
        try {
          const response = await fetch(state.settings.apiUrl, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${state.settings.apiKey}`
            },
            body: JSON.stringify({
              model: "gpt-3.5-turbo", // Or gpt-4o-mini
              messages: [
                { role: "system", content: "You are Aphrodite, the seductive, playful, and strict host of 'The Vault', a premium adult party game. Keep responses under 3 sentences. Be cinematic, luxurious, and slightly mischievous. Judge disputes fairly but with flair." },
                { role: "user", content: msg }
              ]
            })
          });
          const data = await response.json();
          const reply = data.choices?.[0]?.message?.content || "The spirits are silent. Try again, darling.";
          document.getElementById(typingId).remove();
          addAiMsg(reply, 'bot');
        } catch (e) {
          document.getElementById(typingId).remove();
          addAiMsg("My connection to the ether is blocked. Check your API key, darling.", 'bot');
        }
      } else {
        // Fallback local logic
        setTimeout(() => {
          document.getElementById(typingId).remove();
          let reply = "The Vault is listening. Ask me about the rules, skipping, or cheating.";
          const lower = msg.toLowerCase();
          if (lower.includes('rule') || lower.includes('how')) reply = "The rules are simple, darling: Roll, obey Aphrodite, and escalate the heat. Refuse, and you take a penalty. 😈";
          if (lower.includes('skip') || lower.includes('pass')) reply = "Aphrodite doesn't accept 'no' easily. You can skip, but you must take a drink penalty and lose 10 XP. 🍷";
          if (lower.includes('cheat') || lower.includes('lie')) reply = "If I catch anyone lying, I will force them to draw a 'Vault Elite' card on the next turn. Honesty is the ultimate aphrodisiac. 💋";
          addAiMsg(reply, 'bot');
        }, 800);
      }
    }

    function addAiMsg(text, type, id = null) {
      const container = document.getElementById('ai-messages');
      const div = document.createElement('div');
      div.className = `ai-msg ${type}`;
      div.innerHTML = text;
      if (id) div.id = id;
      container.appendChild(div);
      container.scrollTop = container.scrollHeight;
    }

    // --- PERSISTENCE ---
    function saveGame() {
      const saveData = {
        players: state.players,
        currentTurn: state.currentTurn,
        vibe: state.vibe,
        mood: state.mood,
        intensity: state.intensity,
        pin: state.pin,
        memory: state.memory,
        relationships: state.relationships,
        achievements: Array.from(state.achievements),
        turnCount: state.turnCount,
        settings: state.settings
      };
      localStorage.setItem('theVault_v10_save', JSON.stringify(saveData));
    }

    function loadGame() {
      const saved = localStorage.getItem('theVault_v10_save');
      if (saved) {
        try {
          const data = JSON.parse(saved);
          Object.assign(state, data, { achievements: new Set(data.achievements) });
          if (state.players.length > 0) {
            document.getElementById('setup-container').classList.add('hidden');
            document.getElementById('game-ui').classList.add('active');
            initBoard();
            updateUI();
            if (state.isLocked) toggleLock();
            if (state.settings.apiKey) {
              document.getElementById('ai-status').classList.remove('offline');
              document.querySelector('.ai-fab').classList.add('pulse');
            }
          }
        } catch(e) {
          console.error("Save corrupted", e);
        }
      }
    }

    function randomFrom(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

    // --- INIT ---
    window.onload = loadGame;
  </script>
</body>
</html>
