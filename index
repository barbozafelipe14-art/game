  <!-- SETTINGS MODAL -->
  <div class="modal-overlay" id="settings-modal">
    <div class="panel-content">
      <div class="panel-title">Settings <span style="cursor:pointer; font-size:24px;" onclick="closeSettings()">✕</span></div>
      
      <div class="panel-section">
        <div class="panel-label">AI Director API Key</div>
        <div class="setup-desc" style="margin-bottom: 8px; font-size: 12px;">Paste your OpenAI-compatible API key to enable live AI refereeing and dynamic prompt generation.</div>
        <input type="password" class="setup-input" id="api-key-input" placeholder="sk-..." style="font-size: 12px;">
        <input type="text" class="setup-input" id="api-url-input" placeholder="https://api.openai.com/v1/chat/completions" value="https://api.openai.com/v1/chat/completions" style="font-size: 12px; margin-top: 8px;">
        <button class="btn btn-secondary" style="margin-top: 8px; width: 100%;" onclick="saveSettings()">Save API Settings</button>
      </div>

      <div class="panel-section">
        <div class="panel-label">Game Intensity</div>
        <input type="range" min="1" max="5" id="settings-intensity" style="width: 100%; accent-color: var(--accent);">
      </div>

      <div class="panel-section">
