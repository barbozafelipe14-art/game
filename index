        <button class="host-btn" onclick="hostAction('aphrodite')">Force Aphrodite Event <span>🌹</span></button>
        <button class="host-btn" onclick="hostAction('reset')">Reset All Scores <span>🔄</span></button>
        <button class="host-btn" style="border-color: #ff3b3b; color: #ff3b3b;" onclick="hostAction('end')">End Session <span>🚪</span></button>
