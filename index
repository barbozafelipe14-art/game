</head>
<body>

  <!-- SETUP FLOW -->
  <div id="setup-container">
    <!-- Step 1: Count -->
    <div class="setup-screen" id="step-1">
      <div class="setup-header">
        <div class="setup-step">Step 01 / 05</div>
        <div class="setup-title">How many people are playing?</div>
        <div class="setup-desc">This shapes which games unlock tonight.</div>
      </div>
      <div class="setup-options" id="player-count-options">
        <div class="setup-option" data-val="2"><h3>2 · Couple</h3><p>Intimate & Deep</p></div>
        <div class="setup-option" data-val3"><h3>3 · Trio</h3><p>Dynamic & Flirty</p></div>
        <div class="setup-option" data-val="4"><h3>4 · Group</h3><p>Perfect Balance</p></div>
        <div class="setup-option" data-val="6"><h3>6 · Party</h3><p>Chaos & Fun</p></div>
        <div class="setup-option" data-val="8"><h3>8 · Big Party</h3><p>Maximum Chaos</p></div>
      </div>
      <div class="setup-footer"><button class="btn btn-primary" onclick="nextStep(1)">Continue</button></div>
    </div>

    <!-- Step 2: Details -->
    <div class="setup-screen hidden" id="step-2">
      <div class="setup-header">
        <div class="setup-step">Step 02 / 05</div>
        <div class="setup-title">Who's in the vault tonight?</div>
        <div class="setup-desc">First names only. Mark the host with ★.</div>
      </div>
      <div class="setup-options" id="names-container" style="overflow-y: auto; padding-right: 4px;"></div>
      <div class="setup-footer">
        <button class="btn btn-secondary" onclick="prevStep(2)">Back</button>
        <button class="btn btn-primary" onclick="nextStep(2)">Continue</button>
      </div>
    </div>

    <!-- Step 3: Vibe -->
    <div class="setup-screen hidden" id="step-3">
      <div class="setup-header">
        <div class="setup-step">Step 03 / 05</div>
        <div class="setup-title">What kind of night is this?</div>
        <div class="setup-desc">This sets the entire tone of the game.</div>
